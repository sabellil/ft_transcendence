// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

//Generer un Prisma CLient JS, outil pour faire findMany() ou encore create()
generator client {
  provider = "prisma-client-js"
}

//Fournir a Prisma la bdd
datasource db {
  provider = "postgresql"
}

//Modele pour notre premiere table SQL
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  username  String   @unique
  password  String
  avatar    String?
  isOnline  Boolean  @default(false)
  createdAt DateTime @default(now())

  sentFriendships     Friendship[] @relation("SentFriendships")
  receivedFriendships Friendship[] @relation("ReceivedFriendships")

  ownedOrganizations Organization[]
  organizations      OrganizationMember[]
}

model Friendship {
  id         Int @id @default(autoincrement())

  senderId   Int
  receiverId Int

  status     String

  sender   User @relation("SentFriendships", fields: [senderId], references: [id])
  receiver User @relation("ReceivedFriendships", fields: [receiverId], references: [id])

  createdAt DateTime @default(now())
}

model Organization {
  id      Int @id @default(autoincrement())

  name    String

  ownerId Int
  owner   User @relation(fields: [ownerId], references: [id])

  members OrganizationMember[]
}

model OrganizationMember {
  id             Int @id @default(autoincrement())

  organizationId Int
  userId         Int

  role           String

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User @relation(fields: [userId], references: [id])
}